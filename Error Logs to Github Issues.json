      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n    COUNT(*) FILTER (WHERE timestamp >= NOW() - INTERVAL '24 hours') AS count_24h,\n    COUNT(*) FILTER (WHERE timestamp >= NOW() - INTERVAL '30 days') AS count_30d\nFROM app_errors\nWHERE location='{{ $json.location }}';",
        "options": {}

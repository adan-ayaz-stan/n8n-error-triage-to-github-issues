    {
      "parameters": {
        "jsCode": "const c24 = $json.count_24h || 0;\nconst c30 = $json.count_30d || 0;\n\nconst webhook = $(\"Web App calls webhook when error\").item.json.body;\nconst status = webhook.status || \"Unknown\";\nconst loc = webhook.location || \"Unknown\";\nconst ver = webhook.app_version || \"Unknown\";\n\nlet severity = \"Low\";\nlet is_urgent = false;\n\nif (c24 > 50) {\n    severity = \"Critical\";\n    is_urgent = true;\n} else if (c24 > 10) {\n    severity = \"High\";\n    is_urgent = true;\n} else if (c30 > 50) {\n    severity = \"Medium\";\n}\n\nreturn {\n    severity_level: severity,\n    is_urgent: is_urgent,\n    issue_title: `Error ${status} : ${ver}_${loc}`,\n    label: `error:${loc}`,\n    original_error: webhook \n};"
      },
